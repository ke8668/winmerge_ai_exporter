+bool DiffEngine::CompareFiles(
+    const FileBuffer& left,
+    const FileBuffer& right,
+    DiffResult& result,
+    const CompareOptions& opts) {
+    if (left.empty() || right.empty()) {
+        result.SetError(ERR_EMPTY_FILE);
+        return false;
+    }
+    if (opts.UseParallelDiff()) {
+        return RunParallelDiff(left, right, result, opts);
+    }
+    return RunDiff(left, right, result, opts);
 }
 
+bool DiffEngine::RunParallelDiff(
+    const FileBuffer& left,
+    const FileBuffer& right,
+    DiffResult& result,
+    const CompareOptions& opts) {
+    std::mutex result_mutex;
+    std::vector<std::thread> workers;
+    ConcurrentQueue<DiffHunk> hunk_queue;
+    // Partition lines into chunks and diff in parallel
+    const size_t chunk_size = opts.ChunkSize();
+    for (size_t i = 0; i < left.LineCount(); i += chunk_size) {
+        workers.emplace_back([&, i]() {
+            auto chunk_result = DiffChunk(left, right, i, chunk_size);
+            std::lock_guard<std::mutex> lock(result_mutex);
+            result.Append(chunk_result);
+            hunk_queue.Push(std::move(chunk_result));
+        });
+    }
+    for (auto& w : workers) w.join();
+    return !result.HasErrors();
+}
