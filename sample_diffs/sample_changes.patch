+"""
+WinMerge AI Review Plugin
+Exposes export_ai_review_package to the WinMerge plugin host.
+"""
+import sys
+import os
+from pathlib import Path
+
+sys.path.insert(0, str(Path(__file__).parent.parent.parent / "Tools"))
+
+from winmerge_ai_exporter import (
+    load_from_patch_file,
+    export_ai_review_package,
+    estimate_for_diffs,
+)
+
+
+def export_package(patch_path: str, output_dir: str, **kwargs) -> str:
+    """Entry point called by WinMerge plugin host."""
+    diffs = load_from_patch_file(patch_path)
+    out = export_ai_review_package(
+        diffs,
+        output_dir=output_dir,
+        context_lines=kwargs.get("context_lines", 30),
+        skip_whitespace=kwargs.get("skip_whitespace", True),
+        skip_comments=kwargs.get("skip_comments", True),
+    )
+    return str(out)
+
+
+def estimate_tokens(patch_path: str) -> dict:
+    """Estimate token count for a patch file."""
+    diffs = load_from_patch_file(patch_path)
+    est = estimate_for_diffs(diffs)
+    return {
+        "total_tokens": est.estimated_tokens,
+        "estimated_cost_usd": est.estimated_cost_usd,
+        "breakdown": est.breakdown,
+    }
+
+
+if __name__ == "__main__":
+    import json
+    result = export_package(sys.argv[1], sys.argv[2] if len(sys.argv) > 2 else ".")
+    print(result)
